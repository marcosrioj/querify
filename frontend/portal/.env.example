VITE_PORTAL_TENANT_API_URL=http://localhost:5002
VITE_PORTAL_FAQ_API_URL=http://localhost:5010

# Derived from the real backend appsettings in this repository.
VITE_AUTH0_DOMAIN=basefaq.us.auth0.com
VITE_AUTH0_AUDIENCE=https://basefaq.com

# Required for live login. The repo does not currently contain a dedicated Portal SPA client.
VITE_AUTH0_CLIENT_ID=

# Optional. Use when Auth0 password reset should deep-link from the Portal login flow.
VITE_AUTH0_PASSWORD_RESET_URL=
