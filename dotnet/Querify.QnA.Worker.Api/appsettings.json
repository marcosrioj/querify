{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "TenantDb": "Host=host.docker.internal;Port=5432;Database=qf_tenant_db;Username=postgres;Password=Pass123$;",
    "HangfireQnaDb": "Host=host.docker.internal;Port=5432;Database=qf_hangfire_qna_db;Username=postgres;Password=Pass123$;"
  },
  "urls": "http://localhost:5030",
  "HangFire": {
    "SchemaName": "hangfire",
    "PrepareSchemaIfNecessary": true,
    "StartupConnectionMaxRetries": 5,
    "StartupConnectionBaseDelaySeconds": 1,
    "StartupConnectionMaxDelaySeconds": 60,
    "AllowDegradedModeWithoutStorage": true,
    "Dashboard": {
      "Enabled": true,
      "UserName": "admin",
      "Password": "Pass123$"
    }
  },
  "RabbitMQ": {
    "Hostname": "host.docker.internal",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "QueueName": "qna.source-upload.completed.worker.v1",
    "PrefetchCount": 8,
    "ConcurrencyLimit": 4,
    "Retry": {
      "Count": 3,
      "IntervalMilliseconds": 500
    },
    "Exchange": {
      "Name": "qna.source-upload.completed.v1",
      "Type": "fanout"
    }
  },
  "ObjectStorage": {
    "Endpoint": "https//dev.portal.querify.net/s3",
    "PublicEndpoint": "http://localhost:5900",
    "Region": "us-east-1",
    "AccessKey": "minio",
    "SecretKey": "Pass123$",
    "Bucket": "querify-sources",
    "ForcePathStyle": true,
    "UploadPresignTtlMinutes": 10,
    "DownloadPresignTtlMinutes": 5,
    "ServerSideEncryptionMode": null
  },
  "SourceUpload": {
    "MaxUploadBytes": 52428800,
    "PendingExpirationHours": 24,
    "ThreatScanningMode": "Noop"
  },
  "QnAWorker": {
    "PendingSourceUploadExpiry": {
      "Enabled": true,
      "PollingIntervalSeconds": 3600
    }
  }
}
