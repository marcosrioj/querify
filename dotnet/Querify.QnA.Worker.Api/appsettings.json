{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "TenantDb": "Host=host.docker.internal;Port=5432;Database=qf_tenant_db;Username=postgres;Password=Pass123$;"
  },
  "urls": "http://localhost:5030",
  "HangFire": {
    "ConnectionString": "Host=host.docker.internal;Port=5432;Database=qf_hangfire_db;Username=postgres;Password=Pass123$;",
    "Dashboard": {
      "Enabled": true,
      "UserName": "admin",
      "Password": "Pass123$"
    }
  },
  "ObjectStorage": {
    "Endpoint": "http://localhost:5900",
    "PublicEndpoint": "http://localhost:5900",
    "Region": "us-east-1",
    "AccessKey": "minio",
    "SecretKey": "Pass123$",
    "Bucket": "querify-sources",
    "ForcePathStyle": true,
    "UploadPresignTtlMinutes": 10,
    "DownloadPresignTtlMinutes": 5,
    "ServerSideEncryptionMode": null
  },
  "SourceUpload": {
    "MaxUploadBytes": 52428800,
    "PendingExpirationHours": 24,
    "ThreatScanningMode": "Noop"
  },
  "QnAWorker": {
    "SourceUploadVerification": {
      "Enabled": true,
      "BatchSize": 20,
      "CronExpression": "*/1 * * * *",
      "QueueName": "qna-source-upload",
      "RecurringJobId": "qna-source-upload-verification"
    },
    "PendingSourceUploadExpiry": {
      "Enabled": true,
      "PollingIntervalSeconds": 3600
    }
  }
}
