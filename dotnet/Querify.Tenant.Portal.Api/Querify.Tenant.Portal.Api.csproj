<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.2"/>
        <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="10.0.1">
            <PrivateAssets>all</PrivateAssets>
            <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
        </PackageReference>
    </ItemGroup>

    <ItemGroup>
        <Content Include="..\..\.dockerignore">
            <Link>.dockerignore</Link>
        </Content>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Querify.Common.Infrastructure.Mvc\Querify.Common.Infrastructure.Mvc.csproj"/>
        <ProjectReference Include="..\Querify.Common.Infrastructure.Sentry\Querify.Common.Infrastructure.Sentry.csproj"/>
        <ProjectReference Include="..\Querify.Common.Infrastructure.Swagger\Querify.Common.Infrastructure.Swagger.csproj"/>
        <ProjectReference Include="..\Querify.Common.Infrastructure.ApiErrorHandling\Querify.Common.Infrastructure.ApiErrorHandling.csproj"/>
        <ProjectReference Include="..\Querify.Tenant.Portal.Business.Billing\Querify.Tenant.Portal.Business.Billing.csproj"/>
        <ProjectReference Include="..\Querify.Tenant.Portal.Business.Tenant\Querify.Tenant.Portal.Business.Tenant.csproj"/>
        <ProjectReference Include="..\Querify.Tenant.Portal.Business.User\Querify.Tenant.Portal.Business.User.csproj"/>
    </ItemGroup>

</Project>
