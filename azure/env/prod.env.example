BASEFAQ_STAGE=prod
BASEFAQ_BASE_DOMAIN=basefaq.com

# Azure subscription + region
AZURE_SUBSCRIPTION_ID=
AZURE_LOCATION=eastus
AZURE_RESOURCE_GROUP=rg-basefaq-prod

# Core platform resources
AZURE_CONTAINERAPPS_ENVIRONMENT=cae-basefaq-prod
AZURE_ACR_NAME=basefaqprodacr
AZURE_ACR_SKU=Standard

# PostgreSQL Flexible Server (globally unique name)
AZURE_POSTGRES_SERVER_NAME=basefaq-pg-prod
AZURE_POSTGRES_ADMIN_USER=basefaquser
AZURE_POSTGRES_ADMIN_PASSWORD=
AZURE_POSTGRES_SKU_NAME=Standard_D2s_v3
AZURE_POSTGRES_VERSION=16
TENANT_DB_NAME=bf_tenant_db
FAQ_DB_NAME=bf_faq_db_01
FAQ_DB_NAME_2=bf_faq_db_02

# Optional local bootstrap IP
POSTGRES_CLIENT_IP=auto

# Redis (globally unique name)
AZURE_REDIS_NAME=basefaq-redis-prod
AZURE_REDIS_SKU=Standard
AZURE_REDIS_VM_SIZE=C1

# RabbitMQ container in ACI (DNS label must be globally unique)
AZURE_RABBITMQ_CONTAINER_NAME=basefaq-rabbitmq-prod
AZURE_RABBITMQ_DNS_LABEL=basefaq-rabbitmq-prod-001
RABBITMQ_USERNAME=basefaq
RABBITMQ_PASSWORD=

# Deployment behavior
BASEFAQ_ENVIRONMENT=Production
CONTAINERAPP_PREFIX=basefaq-prod
IMAGE_TAG=
BOOTSTRAP_MODE=essential

# Domains (basefaq.com convention)
FAQ_PORTAL_DOMAIN=faq.basefaq.com
FAQ_PUBLIC_DOMAIN=faq-public.basefaq.com
TENANT_BACKOFFICE_DOMAIN=tenant.basefaq.com
TENANT_PORTAL_DOMAIN=tenant-portal.basefaq.com
AI_DOMAIN=ai.basefaq.com

# CORS
CORS_ALLOW_ANY_ORIGINS=false
CORS_ALLOWED_ORIGINS="https://faq.basefaq.com;https://faq-public.basefaq.com;https://tenant.basefaq.com;https://tenant-portal.basefaq.com;https://ai.basefaq.com"

# Auto-generated by provision.sh
TENANT_DB_CONNECTION_STRING=
FAQ_DB_CONNECTION_STRING=
REDIS_HOST=
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_USE_SSL=true
RABBITMQ_HOST=
RABBITMQ_PORT=5672

# Auth0 (manual)
AUTHORITY_URL=
AUTH_AUDIENCE=https://api.basefaq.com
SWAGGER_AUTH_CLIENT_ID=
SWAGGER_AUTH_AUDIENCE=https://api.basefaq.com
SWAGGER_AUTH_AUTHORIZE_ENDPOINT=
SWAGGER_AUTH_TOKEN_ENDPOINT=

# Auto-generated by bootstrap-data.sh
AI_USER_ID=

# Optional telemetry
OTLP_ENDPOINT=
