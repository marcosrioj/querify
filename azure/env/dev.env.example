BASEFAQ_STAGE=dev
BASEFAQ_BASE_DOMAIN=basefaq.com

# Azure subscription + region
AZURE_SUBSCRIPTION_ID=
AZURE_LOCATION=eastus
AZURE_RESOURCE_GROUP=rg-basefaq-dev

# Core platform resources
AZURE_CONTAINERAPPS_ENVIRONMENT=cae-basefaq-dev
AZURE_ACR_NAME=basefaqdevacr
AZURE_ACR_SKU=Basic

# PostgreSQL Flexible Server (globally unique name)
AZURE_POSTGRES_SERVER_NAME=basefaq-pg-dev
AZURE_POSTGRES_ADMIN_USER=basefaquser
AZURE_POSTGRES_ADMIN_PASSWORD=
AZURE_POSTGRES_SKU_NAME=Standard_B1ms
AZURE_POSTGRES_VERSION=16
TENANT_DB_NAME=bf_tenant_db
FAQ_DB_NAME=bf_faq_db_01
FAQ_DB_NAME_2=bf_faq_db_02

# Optional local bootstrap IP
# auto = detect your current public IP and allow it on PostgreSQL firewall.
POSTGRES_CLIENT_IP=auto

# Redis (globally unique name)
AZURE_REDIS_NAME=basefaq-redis-dev
AZURE_REDIS_SKU=Basic
AZURE_REDIS_VM_SIZE=C0

# RabbitMQ container in ACI (DNS label must be globally unique)
AZURE_RABBITMQ_CONTAINER_NAME=basefaq-rabbitmq-dev
AZURE_RABBITMQ_DNS_LABEL=basefaq-rabbitmq-dev-001
RABBITMQ_USERNAME=basefaq
RABBITMQ_PASSWORD=

# Deployment behavior
BASEFAQ_ENVIRONMENT=Development
CONTAINERAPP_PREFIX=basefaq-dev
IMAGE_TAG=
BOOTSTRAP_MODE=full

# Domains (basefaq.com convention)
FAQ_PORTAL_DOMAIN=faq.dev.basefaq.com
FAQ_PUBLIC_DOMAIN=faq-public.dev.basefaq.com
TENANT_BACKOFFICE_DOMAIN=tenant.dev.basefaq.com
TENANT_PORTAL_DOMAIN=tenant-portal.dev.basefaq.com
AI_DOMAIN=ai.dev.basefaq.com

# CORS
CORS_ALLOW_ANY_ORIGINS=false
CORS_ALLOWED_ORIGINS="https://faq.dev.basefaq.com;https://faq-public.dev.basefaq.com;https://tenant.dev.basefaq.com;https://tenant-portal.dev.basefaq.com;https://ai.dev.basefaq.com;http://localhost:3000"

# Auto-generated by provision.sh
TENANT_DB_CONNECTION_STRING=
FAQ_DB_CONNECTION_STRING=
REDIS_HOST=
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_USE_SSL=true
RABBITMQ_HOST=
RABBITMQ_PORT=5672

# Auth0 (manual)
AUTHORITY_URL=
AUTH_AUDIENCE=https://api.dev.basefaq.com
SWAGGER_AUTH_CLIENT_ID=
SWAGGER_AUTH_AUDIENCE=https://api.dev.basefaq.com
SWAGGER_AUTH_AUTHORIZE_ENDPOINT=
SWAGGER_AUTH_TOKEN_ENDPOINT=

# Auto-generated by bootstrap-data.sh
AI_USER_ID=

# Optional telemetry
OTLP_ENDPOINT=
